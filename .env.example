# ─────────────────────────────────────────────────────────────────────────────
# CrimeLens AI — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── AI API Keys ──────────────────────────────────────────────────────────────
# Groq API Key — get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Mistral API Key — get yours at https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# ─── AI Model Configuration ───────────────────────────────────────────────────
# Groq model to use (Mistral served via Groq)
GROQ_MODEL=mistral-saba-24b

# ─── Application Configuration ────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=True

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./crime_lens.db

# ─── Data Paths ───────────────────────────────────────────────────────────────
DATA_DIR=./data
REPORTS_DIR=./reports
