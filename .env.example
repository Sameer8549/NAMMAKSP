# ─────────────────────────────────────────────────────────────────────────────
# CrimeLens AI — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── AI API Keys ──────────────────────────────────────────────────────────────
# Groq API Key — get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Mistral API Key — get yours at https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# Sarvam AI API Key — used for translation, language detection, STT, and TTS
SARVAM_API_KEY=your_sarvam_api_key_here

# ─── AI Model Configuration ───────────────────────────────────────────────────
# Groq model to use for core crime reasoning
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER_MODE=cloud
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_API_KEY=local-development-key
LOCAL_LLM_MODEL=llama3.1:8b

# Raw audio cannot be text-redacted before cloud transcription. Keep false for
# production; enable only for approved synthetic/demo voice input.
ALLOW_CLOUD_AUDIO=false

# Authentication: production uses Catalyst. Legacy demo users are available
# only when explicitly enabled for local demonstrations.
AUTH_MODE=catalyst
DEMO_MODE=false
NAMMAKSP_ADMIN_ROLES=Admin,App Admin,App Administrator
NAMMAKSP_INVESTIGATOR_ROLES=Investigator

# Sarvam language service defaults
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TRANSLATE_MODEL=mayura:v1
SARVAM_TTS_SPEAKER=shubh

# ─── Application Configuration ────────────────────────────────────────────────
APP_HOST=127.0.0.1
SESSION_TTL_SECONDS=28800
APP_PORT=8000
DEBUG=True

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./crime_lens.db

# ─── Data Paths ───────────────────────────────────────────────────────────────
DATA_DIR=./data
REPORTS_DIR=./reports
