{
  "command": "python3 start_app.py",
  "stack": "python_3_12",
  "build_path": ".",
  "memory": 512,
  "env_variables": {
    "DATA_DIR": "data",
    "REPORTS_DIR": "reports",
    "GROQ_MODEL": "llama-3.3-70b-versatile",
    "SARVAM_BASE_URL": "https://api.sarvam.ai",
    "SARVAM_STT_MODEL": "saaras:v3",
    "SARVAM_TTS_MODEL": "bulbul:v3",
    "SARVAM_TRANSLATE_MODEL": "mayura:v1",
    "SARVAM_TTS_SPEAKER": "shubh",
    "LLM_PROVIDER_MODE": "cloud",
    "ALLOW_CLOUD_AUDIO": "true",
    "AUTH_MODE": "catalyst",
    "DEMO_MODE": "true",
    "NAMMAKSP_ADMIN_ROLES": "Admin,App Admin,App Administrator",
    "NAMMAKSP_INVESTIGATOR_ROLES": "Investigator",
    "NAMMAKSP_QUICKML_ENABLED": "true",
    "NAMMAKSP_QUICKML_PIPELINE_ID": "716000000002088",
    "NAMMAKSP_QUICKML_MODEL_ID": "716000000002091",
    "NAMMAKSP_QUICKML_ENDPOINT_ID": "716000000002147",
    "NAMMAKSP_QUICKML_ENDPOINT_URL": "https://api.catalyst.zoho.in/quickml/v1/project/43505000000015001/endpoints/predict",
    "NAMMAKSP_CRON_ENABLED": "true",
    "NAMMAKSP_SIGNALS_ENABLED": "true",
    "NAMMAKSP_SIGNALS_PUBLISHER_ID": "6060000000021091",
    "NAMMAKSP_API_GATEWAY_ENABLED": "true"
